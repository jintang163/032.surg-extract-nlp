package rules

import com.surg.extract.dto.QcCheckFact
import com.surg.extract.dto.QcCheckResult
import com.surg.extract.dto.QcCheckResult.QcViolation
import java.util.ArrayList
import java.util.List

rule "QC-C001: 患者姓名缺失"
    salience 100
    when
        $fact : QcCheckFact(patientName == null || patientName.length() == 0)
    then
        List fields = new ArrayList();
        fields.add("patientName");
        $fact.getViolations().add(new QcViolation(
            "QC-C001", "患者姓名缺失", "COMPLETENESS",
            "ERROR", "患者姓名为必填项，当前为空", fields
        ));
end

