<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.surg.extract.mapper.SurgeryRecordMapper">

    <resultMap id="BaseResultMap" type="com.surg.extract.entity.SurgeryRecord">
        <id column="id" property="id"/>
        <result column="record_no" property="recordNo"/>
        <result column="patient_id" property="patientId"/>
        <result column="patient_name" property="patientName"/>
        <result column="hospital_no" property="hospitalNo"/>
        <result column="gender" property="gender"/>
        <result column="age" property="age"/>
        <result column="department" property="department"/>
        <result column="original_file_name" property="originalFileName"/>
        <result column="file_type" property="fileType"/>
        <result column="file_path" property="filePath"/>
        <result column="file_size" property="fileSize"/>
        <result column="ocr_text" property="ocrText"/>
        <result column="processed_text" property="processedText"/>
        <result column="upload_user_id" property="uploadUserId"/>
        <result column="upload_user_name" property="uploadUserName"/>
        <result column="upload_time" property="uploadTime"/>
        <result column="process_status" property="processStatus"/>
        <result column="process_message" property="processMessage"/>
        <result column="ocr_start_time" property="ocrStartTime"/>
        <result column="ocr_end_time" property="ocrEndTime"/>
        <result column="ner_start_time" property="nerStartTime"/>
        <result column="ner_end_time" property="nerEndTime"/>
        <result column="patient_confirmed" property="patientConfirmed"/>
        <result column="confirm_user_id" property="confirmUserId"/>
        <result column="confirm_time" property="confirmTime"/>
        <result column="fill_duration" property="fillDuration"/>
        <result column="manual_duration_est" property="manualDurationEst"/>
        <result column="his_synced" property="hisSynced"/>
        <result column="his_sync_time" property="hisSyncTime"/>
        <result column="his_sync_message" property="hisSyncMessage"/>
        <result column="created_time" property="createdTime"/>
        <result column="updated_time" property="updatedTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <select id="selectByConditions" resultMap="BaseResultMap">
        SELECT * FROM surgery_record
        WHERE deleted = 0
        <if test="patientName != null and patientName != ''">
            AND patient_name LIKE CONCAT('%', #{patientName}, '%')
        </if>
        <if test="hospitalNo != null and hospitalNo != ''">
            AND hospital_no = #{hospitalNo}
        </if>
        <if test="status != null and status != ''">
            AND process_status = #{status}
        </if>
        <if test="startDate != null">
            AND DATE(upload_time) &gt;= #{startDate}
        </if>
        <if test="endDate != null">
            AND DATE(upload_time) &lt;= #{endDate}
        </if>
        ORDER BY upload_time DESC
        LIMIT #{offset}, #{limit}
    </select>

    <select id="countByConditions" resultType="java.lang.Long">
        SELECT COUNT(*) FROM surgery_record
        WHERE deleted = 0
        <if test="patientName != null and patientName != ''">
            AND patient_name LIKE CONCAT('%', #{patientName}, '%')
        </if>
        <if test="hospitalNo != null and hospitalNo != ''">
            AND hospital_no = #{hospitalNo}
        </if>
        <if test="status != null and status != ''">
            AND process_status = #{status}
        </if>
        <if test="startDate != null">
            AND DATE(upload_time) &gt;= #{startDate}
        </if>
        <if test="endDate != null">
            AND DATE(upload_time) &lt;= #{endDate}
        </if>
    </select>

    <update id="updateStatus">
        UPDATE surgery_record
        SET process_status = #{status},
            <if test="message != null and message != ''">
                process_message = #{message},
            </if>
            updated_time = NOW()
        WHERE id = #{id}
    </update>

    <update id="updateNerTime">
        UPDATE surgery_record
        SET ner_start_time = #{startTime},
            ner_end_time = #{endTime},
            updated_time = NOW()
        WHERE id = #{id}
    </update>

    <update id="updateOcrTime">
        UPDATE surgery_record
        SET ocr_start_time = #{startTime},
            ocr_end_time = #{endTime},
            updated_time = NOW()
        WHERE id = #{id}
    </update>

    <select id="selectRecentCompletedByDepartment" resultMap="BaseResultMap">
        SELECT id, department, upload_user_id, original_file_name, template_id, upload_time, process_status
        FROM surgery_record
        WHERE deleted = 0
          AND upload_time &gt;= #{fromTime}
          AND process_status IN ('NER_DONE', 'COMPLETED')
          AND template_id IS NOT NULL
        <if test="department != null and department != ''">
            AND department = #{department}
        </if>
        ORDER BY upload_time DESC
        LIMIT 500
    </select>

</mapper>
