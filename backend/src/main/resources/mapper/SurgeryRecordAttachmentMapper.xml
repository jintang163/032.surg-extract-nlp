<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.surg.extract.mapper.SurgeryRecordAttachmentMapper">

    <resultMap id="BaseResultMap" type="com.surg.extract.entity.SurgeryRecordAttachment">
        <id column="id" property="id"/>
        <result column="record_id" property="recordId"/>
        <result column="original_file_name" property="originalFileName"/>
        <result column="file_path" property="filePath"/>
        <result column="file_type" property="fileType"/>
        <result column="file_size" property="fileSize"/>
        <result column="attachment_type" property="attachmentType"/>
        <result column="process_status" property="processStatus"/>
        <result column="process_message" property="processMessage"/>
        <result column="extracted_text" property="extractedText"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="created_time" property="createdTime"/>
        <result column="updated_time" property="updatedTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <select id="selectByRecordId" resultMap="BaseResultMap">
        SELECT * FROM surgery_record_attachment
        WHERE record_id = #{recordId}
          AND deleted = 0
        ORDER BY sort_order ASC, id ASC
    </select>

    <select id="selectByRecordIdAndType" resultMap="BaseResultMap">
        SELECT * FROM surgery_record_attachment
        WHERE record_id = #{recordId}
          AND attachment_type = #{attachmentType}
          AND deleted = 0
        ORDER BY sort_order ASC, id ASC
    </select>

    <update id="updateStatus">
        UPDATE surgery_record_attachment
        SET process_status = #{status},
            process_message = #{message},
            updated_time = NOW()
        WHERE id = #{id}
    </update>

    <update id="updateExtractedText">
        UPDATE surgery_record_attachment
        SET extracted_text = #{extractedText},
            updated_time = NOW()
        WHERE id = #{id}
    </update>

</mapper>
